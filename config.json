{
	"name": "Address Autocompletion",

	"namespace": "Vanderbilt\\AddressExternalModule",

	"description": "This module takes address coordinates from fields specified and autocompletes a street address. Requires a Google API key, an https connection, and a municipal GeoJSON file of type FeatureCollection. An additional neighbourhood boundary check can be achieved by adding an additional FeatureCollecion GeoJSON. A list of neighbourhood names is also required if this feature is used.",

	"authors": [
	  {
		"name": "Scott J. Pearson",
		"email": "datacore@vumc.org",
		"institution": "Vanderbilt University Medical Center"
	  },
	  {
		"name": "Mark McEver",
		"email": "datacore@vumc.org",
		"institution": "Vanderbilt University Medical Center"
	  },
	  {
		"name": "Kyle McGuffin",
		"email": "datacore@vumc.org",
		"institution": "Vanderbilt University Medical Center"
	  }
	  {
		"name": "Devin Foley",
		"email": "foleyd3@mcmaster.ca",
		"institution": "McMaster University"
	  }
	],

	"permissions": [
		"hook_data_entry_form",
		"hook_survey_page"
	],

	"links": {
	},

	"project-settings": [
		{
			"key": "google-api-key",
			"name": "Google API Key",
			"required": true,
			"type": "text"
		},
		{
			"key": "autocomplete",
			"name": "Autocomplete Field (text only)",
			"required": true,
			"type": "field-list",
			"repeatable": false,
			"autocomplete": true
		},
		{
			"key": "street-number",
			"name": "Street Number Field",
			"required": false,
			"type": "field-list",
			"repeatable": false,
			"autocomplete": true
		},
		{
			"key": "street",
			"name": "Street Field",
			"required": false,
			"type": "field-list",
			"repeatable": false,
			"autocomplete": true
		},
		{
			"key": "city",
			"name": "City Field",
			"required": false,
			"type": "field-list",
			"repeatable": false,
			"autocomplete": true
		},
		{
			"key": "county",
			"name": "County Field",
			"required": false,
			"type": "field-list",
			"repeatable": false,
			"autocomplete": true
		},
		{
			"key": "state",
			"name": "State Field",
			"required": false,
			"type": "field-list",
			"repeatable": false,
			"autocomplete": true
		},
		{
			"key": "zip",
			"name": "Zip/Postal Code Field",
			"required": false,
			"type": "field-list",
			"repeatable": false,
			"autocomplete": true
		},
		{
			"key": "country",
			"name": "Country Field",
			"required": false,
			"type": "field-list",
			"repeatable": false,
			"autocomplete": true
		},
		{
			"key": "latitude",
			"name": "Latitude Field",
			"required": false,
			"type": "field-list",
			"repeatable": false,
			"autocomplete": true
		},
		{
			"key": "longitude",
			"name": "Longitude Field",
			"required": false,
			"type": "field-list",
			"repeatable": false,
			"autocomplete": true
		},
		{
			"key": "import-google-api",
			"name": "Import Google API",
			"required": false,
			"type": "checkbox",
			"repeatable": false
		},
		
		{
			"key": "within_neighbourhood",
			"name": "Within Neighbourhood Field (text)",
			"required": false,
			"type": "field-list",
			"repeatable": false,
			"autocomplete": true
		},
		
		{
			"key": "within_city",
			"name": "Within City (yes/no)",
			"required": false,
			"type": "field-list",
			"repeatable": false,
			"autocomplete": true
		},

		{  
			"key" : "city_boundary",
			"type": "file",
			"name": "City boundary GeoJSON",
			"required": true
		},
		{
			"key" : "neighbourhood_boundaries",
			"type": "file",
			"name": "Neighbourhood boundaries GeoJSON",
			"required": false
		},
	
		{ 
			"key":"approved_neighbourhoods",
			"type": "file",
			"name": "Approved neighbourhoods JSON",
			"required": false
		},
		
		{
			"key":"check_neighbourhood",
			"type": "checkbox",
			"label": "Enable neighbourhood check",
			"default": true,
			"required": false
	]
}
